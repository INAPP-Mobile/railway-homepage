# =============================================================================
# Homepage – Railway Template Environment Variables
# Copy this file to .env (local dev) or set these in the Railway dashboard.
# Variables prefixed with ${{...}} are auto-injected by Railway services.
# =============================================================================

# --- Homepage core configuration ---
# Port that Homepage listens on inside the container.
HOMEPAGE_PORT=3000

# Default theme on first load (dark | light | neon | glassmorphism).
HOMEPAGE_VAR_DEFAULT_THEME=dark

# Server log verbosity (info | debug | warn | error).
LOG_LEVEL=info

# --- Optional cosmetic settings (uncomment to enable) ---
# HOMEPAGE_VAR_TITLE=My Dashboard
# HOMEPAGE_VAR_LANGUAGE=en
# HOMEPAGE_VAR_OPEN_IN_NEW_TAB=true
# HOMEPAGE_VAR_BACKGROUND_IMAGE_URL=https://example.com/bg.jpg
# HOMEPAGE_VAR_BACKGROUND_OPACITY=0.4

# --- Optional env-only config (base64-encoded YAML — no volume needed) ---
# HOMEPAGE_VAR_SETTINGS=<base64>
# HOMEPAGE_VAR_SERVICES=<base64>
# HOMEPAGE_VAR_BOOKMARKS=<base64>
# HOMEPAGE_VAR_WIDGETS=<base64>
