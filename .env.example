# =============================================================================
# Homepage – Railway Template Environment Variables
# Copy this file to .env (local dev) or set these in the Railway dashboard.
# Docs: https://gethomepage.dev/installation/#homepage_allowed_hosts
# =============================================================================

# --- REQUIRED: allowed hosts ------------------------------------------------
# Homepage v1.0+ refuses to serve from any non-localhost URL unless this is set.
# Railway serves from a dynamic *.railway.app domain, so '*' disables the host
# check. For tighter security, set this to your real domain(s), comma-separated
# with NO spaces, e.g. HOMEPAGE_ALLOWED_HOSTS=mydash.railway.app,home.example.com
HOMEPAGE_ALLOWED_HOSTS=*

# --- Optional cosmetic settings (config-substitution tokens) ---------------
# These are only applied if your config YAML references the matching
# {{HOMEPAGE_VAR_XXX}} placeholder. With an empty /app/config they have no
# visible effect until you add a settings.yaml that uses them.
# Default theme on first load (dark | light | neon | glassmorphism).
HOMEPAGE_VAR_DEFAULT_THEME=dark

# Custom dashboard title (e.g., My Dashboard). Leave empty for default.
HOMEPAGE_VAR_TITLE=

# Dashboard language code (e.g., en, fr, de). Leave empty for browser default.
HOMEPAGE_VAR_LANGUAGE=

# --- Port / logging notes ---------------------------------------------------
# Homepage listens on port 3000 internally; Next.js honors Railway's injected
# PORT env var automatically, so no HOMEPAGE_PORT variable is needed. There is
# no LOG_LEVEL env var in Homepage — logging is not user-configurable via env.
